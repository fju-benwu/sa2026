{
  "name": "next-react-firebase-scaffold",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:webpack": "next dev",
    "mcp:start": "npx -y firebase-tools@latest mcp",
    "mcp:start:with-dir": "npx -y firebase-tools@latest mcp --dir .",
    "test": "vitest --run --reporter=default --reporter=html",
    "test:watch": "vitest --watch",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e",
    "playwright:install": "npx playwright install",
    "e2e:ci": "npx playwright install && npx playwright test --reporter=dot",
    "build": "next build",
    "start": "next start",
    "export": "next build && node scripts/collect-export.cjs",
    "deploy:gh-pages": "npm run export && npx gh-pages -d out",
    "deploy": "firebase deploy --only hosting"
  },
  "dependencies": {
    "firebase": "^11.0.0",
    "next": "^16.1.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@vitest/ui": "^4.0.18",
    "jsdom": "^27.0.1",
    "vitest": "^4.0.18"
  }
}
